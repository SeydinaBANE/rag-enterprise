{
  "title": "RAG Enterprise — Overview",
  "uid": "rag-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requêtes / minute",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(rag_query_total[1m])) by (collection)",
          "legendFormat": "{{collection}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Streams SSE actifs",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "rag_active_streams", "legendFormat": "streams" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Taux de feedback positif",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(rag_feedback_total{value=\"positive\"}[5m]) / (rate(rag_feedback_total{value=\"positive\"}[5m]) + rate(rag_feedback_total{value=\"negative\"}[5m]) + 0.0001)",
          "legendFormat": "feedback +"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total requêtes (dernière heure)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "targets": [
        { "expr": "increase(rag_query_total[1h])", "legendFormat": "requêtes" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" } }
      }
    },
    {
      "id": 5,
      "title": "Tokens LLM (dernière heure)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
      "targets": [
        { "expr": "increase(rag_tokens_used_total[1h])", "legendFormat": "tokens" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" } }
      }
    },
    {
      "id": 6,
      "title": "Latence RAG — P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_query_latency_seconds_bucket[5m])) by (le, collection))",
          "legendFormat": "P50 {{collection}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_query_latency_seconds_bucket[5m])) by (le, collection))",
          "legendFormat": "P95 {{collection}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rag_query_latency_seconds_bucket[5m])) by (le, collection))",
          "legendFormat": "P99 {{collection}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 7,
      "title": "Feedback 👍 / 👎 dans le temps",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "increase(rag_feedback_total{value=\"positive\"}[5m])",
          "legendFormat": "👍 positif"
        },
        {
          "expr": "increase(rag_feedback_total{value=\"negative\"}[5m])",
          "legendFormat": "👎 négatif"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "👍 positif" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "👎 négatif" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "id": 8,
      "title": "Documents ingérés par collection",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rag_documents_ingested_total) by (collection)",
          "legendFormat": "{{collection}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 9,
      "title": "Requêtes par rôle utilisateur",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(increase(rag_query_total[1h])) by (user_role)",
          "legendFormat": "{{user_role}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 10,
      "title": "HTTP — Latence API (toutes routes)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "P95 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    }
  ]
}
