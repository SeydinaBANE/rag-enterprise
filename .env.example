# ── LLM via OpenRouter ────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Modèle à utiliser — voir https://openrouter.ai/models
# Exemples : anthropic/claude-3.5-sonnet | openai/gpt-4o | mistralai/mistral-large
LLM_MODEL=anthropic/claude-haiku-4.5

# ── Embeddings ────────────────────────────────────────
# Modèle local fastembed — aucune clé API requise
# Options : BAAI/bge-m3 (1024d, qualité) | intfloat/multilingual-e5-small (384d, vitesse)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384

# ── Reranker (optionnel) ──────────────────────────────
COHERE_API_KEY=           # laisser vide pour fallback cosinus

# ── Base de données ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/ragdb
SYNC_DATABASE_URL=postgresql://rag:rag@localhost:5432/ragdb

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ───────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── Confluence (optionnel) ────────────────────────────
CONFLUENCE_URL=https://yourcompany.atlassian.net
CONFLUENCE_USERNAME=email@company.com
CONFLUENCE_API_TOKEN=

# ── Slack (optionnel) ─────────────────────────────────
SLACK_BOT_TOKEN=xoxb-

# ── Fonctionnalités RAG Phase 2 ───────────────────────
# HyDE : +1 appel LLM par query, améliore le recall
HYDE_ENABLED=false
# Cache Redis TTL pour les réponses non-stream (secondes)
CACHE_TTL_SECONDS=3600
# Rate limiting : requêtes /api/query par minute et par utilisateur
RATE_LIMIT_QUERY_PER_MINUTE=20

# ── LangSmith (optionnel — tracing LLM) ──────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rag-enterprise
